{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug run.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/run.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Python: Debug Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
